# Copy to Streamlit Cloud → App settings → Secrets (or local .streamlit/secrets.toml).
# Do not commit real keys.

GROQ_API_KEY = "your_groq_api_key"
LLM_MODEL = "llama-3.3-70b-versatile"
EMBEDDING_MODEL = "BAAI/bge-small-en-v1.5"
VECTOR_DB_PATH = "data/chroma"
TOP_K = "5"
SIMILARITY_THRESHOLD = "0.65"
LLM_TEMPERATURE = "0.1"
LLM_MAX_TOKENS = "256"
LLM_CONTEXT_CHAR_BUDGET = "6000"
GROQ_MAX_RETRIES = "3"
GROQ_TIMEOUT_SEC = "30"
CLOUD_DEPLOY = "true"

# Optional: nest overrides under [env] instead of top-level keys.
# [env]
# GROQ_API_KEY = "your_groq_api_key"
