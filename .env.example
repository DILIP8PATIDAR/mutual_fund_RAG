# Groq LLM
GROQ_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.3-70b-versatile

# Embeddings (BGE via sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Vector store
VECTOR_DB_PATH=./data/chroma

# Retrieval
TOP_K=5
SIMILARITY_THRESHOLD=0.65

# LLM generation + Groq free-tier rate-limit controls
# Free tier (llama-3.3-70b-versatile): 30 req/min, 1K req/day, 12K tok/min, 100K tok/day
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=256
LLM_CONTEXT_CHAR_BUDGET=6000
GROQ_MAX_RETRIES=3
GROQ_TIMEOUT_SEC=30

# UI: streamlit run ui/streamlit_app.py  (default http://localhost:8501)
# API: uvicorn src.api.main:app --reload  (default http://localhost:8000)
